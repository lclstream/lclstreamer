FROM ghcr.io/prefix-dev/pixi:0.70.2 AS build
WORKDIR /app
# git required for pixi with git deps (stream.py)
RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends git \
    && rm -rf /var/lib/apt/lists/*
# mpi4py links against the OpenMPI ABI thru conda-forge mpi-external stub.
# OpenMPI is built in the runtime stage below
ARG PSANA_VERSION=2extmpi
COPY . /app/lclstreamer
RUN cd lclstreamer && pixi install --locked -q -e psana${PSANA_VERSION} \
    && pixi clean cache --yes \
    && rm -rf /root/.cache/rattler
ENV PATH=/opt/openmpi/bin:$PATH
ENV LD_LIBRARY_PATH=/opt/openmpi/lib:${LD_LIBRARY_PATH:-}
RUN cd lclstreamer && pixi shell-hook -e psana${PSANA_VERSION} -s bash > /shell-hook \
    && echo "#!/bin/bash" > /app/entrypoint.sh \
    && cat /shell-hook >> /app/entrypoint.sh \
    && echo 'exec "$@"' >> /app/entrypoint.sh

FROM ubuntu:26.04
ARG PSANA_VERSION=2extmpi

RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive \
       apt-get install -y \
        build-essential \
        pkg-config\
        file\
        wget\
        ca-certificates\
        --no-install-recommends \
    && rm -rf /var/lib/apt/lists/*

# install open mpi
ARG OMPI_VERSION=4.1.6
# set so apptainer/mpirun launches work without an remote shell agent
ENV OMPI_MCA_plm_rsh_agent=/bin/true 
ENV PATH=/opt/openmpi/bin:$PATH 
ENV LD_LIBRARY_PATH=/opt/openmpi/lib:${LD_LIBRARY_PATH:-}
RUN wget -q https://download.open-mpi.org/release/open-mpi/v4.1/openmpi-${OMPI_VERSION}.tar.bz2 \
    && tar xjf openmpi-${OMPI_VERSION}.tar.bz2 && cd openmpi-${OMPI_VERSION} \
    && ./configure --prefix=/opt/openmpi --quiet > /dev/null \
    && make -j$(nproc) -s all > /dev/null \
    && make -s install > /dev/null \
    && cd .. && rm -rf openmpi-${OMPI_VERSION}*

COPY --from=build /app/lclstreamer/.pixi/envs/psana${PSANA_VERSION} /app/lclstreamer/.pixi/envs/psana${PSANA_VERSION}
COPY --from=build --chmod=0755 /app/entrypoint.sh /app/entrypoint.sh
COPY activation-psana1.sh activation-psana2.sh /app/lclstreamer/
WORKDIR /app/lclstreamer
ENTRYPOINT [ "/app/entrypoint.sh" ]
